# ====== 工作流运行产物(根目录) ======
# 只排除目录里的内容,空目录本身靠 .gitkeep 占位提交
logs/*
!logs/.gitkeep
logs/*/*
!logs/*/.gitkeep
# 工作流跑出来的小说项目(.project_info.json 含 session UUID、CLAUDE 是项目级产物)
projects/*
!projects/.gitkeep
projects/*/*
!projects/*/.gitkeep

